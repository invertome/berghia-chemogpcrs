# Ignore this file itself
.gitignore

# Claude/AI-generated review and planning files
CLAUDE.md
AGENTS.md
Deep_Codebase_Review*.md
ARCHITECTURAL_REVIEW*.md
VALIDATION_REPORT*.md
IMPLEMENTATION_PLAN*.md
PIPELINE_VALIDITY_ASSESSMENT*.md
*_ASSESSMENT.md
*_REVIEW.md

# Claude Code files (local only)
.claude/
.beads/
.claude_resources.json

# Git attributes (local)
.gitattributes

# Local databases (large files, user-specific)
databases/

# Custom HMMs (user-provided)
custom_hmms/

# Reference sequences (large, user-provided)
# Use glob (not bare dirname) so individual exception files below can match.
references/*
references/**/*
# Exceptions: small curated reference CSVs maintained in-repo
!references/hcr_positive_controls.csv
!references/cummins2009_aplysia_chemoreceptors.csv
!references/aplysia_classification_validation.csv
# Curated invertebrate chemoreceptor HMM library (bead -k0g): manifest +
# fetched FASTAs are the source-of-truth for the build. HMM artifacts
# go to results/classification/hmms_curated_chemo/ which the default
# results/ rule excludes.
!references/curated_chemoreceptors_lophotrochozoa/
!references/curated_chemoreceptors_lophotrochozoa/**/*
# Species-tree small manifests + final tree (bead -dnk and children).
# Heavy intermediates (downloaded proteomes, BUSCO outputs, per-gene
# alignments, per-gene trees) live in references/species_tree/cache/
# which is excluded just below.
!references/species_tree/
!references/species_tree/*.tsv
!references/species_tree/*.nwk
!references/species_tree/*.json
!references/species_tree/*.md
references/species_tree/cache/

# Transcriptomes and genomes (large, user-provided)
transcriptomes/
genomes/

# Expression data (user-provided)
expression_data/
expression_data.csv

# Results directory (generated outputs)
results/

# Preliminary / local analysis runs
preliminary/

# Log files
*.log
*.err

# Python cache
__pycache__/
*.pyc

# IDE files
.vscode/
.idea/

# Environment files with secrets
.env
.env.local
*.env

# API keys and credentials
credentials/
secrets/

# Local-only config overrides (e.g. real SLURM_EMAIL, machine-specific paths)
config.local.sh

# Implementation plans / design docs are local artifacts, not committed.
# (Existing tracked plans under docs/plans/ remain in git; this rule is
# forward-looking — new plan files are gitignored.)
docs/plans/

tools/deeptmhmm/
containers/*.sif
external/braker4/
methods_log.md
.gitignore
